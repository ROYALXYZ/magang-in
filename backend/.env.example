# Database
DATABASE_URL=postgresql://user:password@host:port/db?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://user:password@host:port/db

# Auth
JWT_SECRET=your_jwt_secret_here

# URLs
FRONTEND_URL=https://your-frontend.vercel.app/auth/google/callback
PORT=3000

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# AI Service
AI_API_URL=https://api.magangin.online

# Supabase Storage (for CV uploads — production)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# Optional: skip SSL verification (DEV ONLY)
# NODE_TLS_REJECT_UNAUTHORIZED=0
